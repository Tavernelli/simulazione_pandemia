    }

        // ========================================
        // HELP
        // ========================================
        private void showHelpDialog() {
                StringBuilder sb = new StringBuilder();
                sb.append("Simulazione Pandemia — Guida rapida\n\n");
                sb.append("Avvio/Pausa:\n");
                sb.append("- Premi 'Avvia' per iniziare; 'Stop' per mettere in pausa.\n\n");
                sb.append("Parametri:\n");
                sb.append("- Popolazione iniziale: numero di persone nella simulazione.\n");
                sb.append("- Infetti iniziali: valore o % (se spuntato).\n");
                sb.append("- Infettività (%): probabilità di contagio al contatto.\n");
                sb.append("- Asintomatici (%): quota degli infetti senza sintomi.\n");
                sb.append("- Morti per infetti (%): mortalità (abilita la checkbox).\n");
                sb.append("- Immuni per sopravvissuti (%): quota che diventa immune.\n\n");
                sb.append("Azioni sull'area di gioco:\n");
                sb.append("- Seleziona 'Vaccino' o 'Quarantena'.\n");
                sb.append("- Trascina col mouse per selezionare un rettangolo.\n");
                sb.append("  • Vaccino: immunizza le persone nell'area.\n");
                sb.append("  • Quarantena: blocca le persone per 'Tempo quarantena' ms.\n\n");
                sb.append("Legenda colori:\n");
                sb.append("- Grigio: suscettibile.\n");
                sb.append("- Rosso/Arancio: infetto/asintomatico (con bordo blu se in quarantena).\n");
                sb.append("- Giallo: immune/vaccinato.\n");
                sb.append("- Croce rossa: morto.\n\n");
                sb.append("Statistiche:\n");
                sb.append("- Popolazione: viventi. Infetti: numero corrente. Immunizzati: tot immuni.\n");
                sb.append("- Media Infetti: media corrente normalizzata.\n\n");
                sb.append("Suggerimenti prestazioni:\n");
                sb.append("- Evita popolazioni eccessive su PC lenti.\n");
                sb.append("- Chiudi altre applicazioni durante la simulazione.\n");

                javax.swing.JOptionPane.showMessageDialog(this, sb.toString(), "Help", javax.swing.JOptionPane.INFORMATION_MESSAGE);
        }

