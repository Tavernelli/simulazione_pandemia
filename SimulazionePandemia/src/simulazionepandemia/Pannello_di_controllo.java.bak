        private void StartActionPerformed(java.awt.event.ActionEvent evt) {
                if (!sceneBlocked) {
                        if (firstClick) {
                                updatePopulationAndInfected();
                                firstClick = false;
                        }
                        pandemia.setAppState(true);
                        Start.setText("Stop");
                        sceneBlocked = true;
                } else {
                        pandemia.setAppState(false);
                        Start.setText("Start");
                        sceneBlocked = false;
                }
        }

        private void updatePopulationAndInfected() {
                popolazione = ((Integer) PopolazioneIniziale.getValue()).intValue();
                infetti = ((Integer) InfettiIniziali.getValue()).intValue();
                nuoviInfetti = ((Integer) Infettivita.getValue()).intValue();
                immuni = ((Integer) Immuni.getValue()).intValue();
                asintomatici = ((Integer) Asintomatici.getValue()).intValue();
                mortiInfetti = jCheckBoxMortiInfetti.isSelected() ? ((Integer) Morti.getValue()).intValue() : 0;
                if (PerncentualiInfetti.isSelected()) {
                        infetti = Math.round(((float) popolazione) * (((float) infetti) / 100));
                }
                pandemia.SetPopolazioneIniziale(popolazione, infetti);
                pandemia.SetInfettività(nuoviInfetti, popolazione);
                pandemia.SetAsintomatici(asintomatici, nuoviInfetti);
                pandemia.SetmortiInfetti(mortiInfetti, nuoviInfetti);
                pandemia.SetGuaritiImmuni(immuni, nuoviInfetti);
                jLabelPopolazione.setText(String.valueOf(popolazione));
                jLabelInfetti.setText(PerncentualiInfetti.isSelected() ? String.valueOf(infetti) : String.valueOf(InfettiIniziali.getValue()));
                JlabelMediaInfetti.setText(fmt.format(0));
                jLabel6.setText(PerncentualiInfetti.isSelected() ? "Infetti iniziali (%)" : "Infetti iniziali");
        }

        public static void setUI(int popolazioneAggiornata, int infettiAggiornati, double immuniAggiornati) {
                jLabelPopolazione.setText(String.valueOf(popolazioneAggiornata));
                jLabelInfetti.setText(String.valueOf(infettiAggiornati));
                jLabelImmunizzati.setText(String.valueOf((int) immuniAggiornati));
                if (infettiAggiornati > 0) {
                        MediaInfetti = (double) (infettiAggiornati - infetti) / (double) infettiAggiornati;
                } else {
                        MediaInfetti = 0.0;
                }
                JlabelMediaInfetti.setText(fmt.format(MediaInfetti));
        }

        public static int getTempoQuarantena() { return tempoQuarantena; }

        public void setCheckBoxState() {
                if (vuoto.isSelected()) {
                        checkBox = 0; tempoQuarantena = 0; pandemia.RemoveListener();
                } else if (Vaccino.isSelected()) {
                        pandemia.setListener(); tempoQuarantena = 0; checkBox = 1;
                } else if (Quarantena.isSelected()) {
                        pandemia.setListener(); checkBox = -1; tempoQuarantena = ((Integer) TempoQuarantena.getValue()).intValue();
                }
        }

        static public int getCheckBoxState() { return checkBox; }
        public static int getAsintomatici() { return asintomatici; }
        public static int getNuoviInfetti() { return nuoviInfetti; }
        public static int getMortiInfetti() { return mortiInfetti; }
        public static int getImmuniGuariti() { return immuni; }

        private void showHelpDialog() {
                StringBuilder sb = new StringBuilder();
                sb.append("Simulazione Pandemia — Guida rapida\n\n")
                  .append("Avvio/Pausa: usa Avvia/Stop.\n\n")
                  .append("Parametri: contagio, asintomatici, mortalità, immunità.\n")
                  .append("Modalità area: Vaccino immunizza; Quarantena blocca (tempo ms).\n\n")
                  .append("Colori: Grigio suscettibile, Rosso/Arancio infetto/asintomatico, Giallo immune, Croce morto.\n\n")
                  .append("Velocità: slider ms tra aggiornamenti (più alto = più lento).\n");
                JOptionPane.showMessageDialog(this, sb.toString(), "Help", JOptionPane.INFORMATION_MESSAGE);
        }

