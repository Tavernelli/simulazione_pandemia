    // GESTORI EVENTI RADIO BUTTON
    // ========================================
    
    /**
     * Gestore del cambiamento di stato del radio button "Vuoto".
     * Disattiva qualsiasi modalità di intervento.
        * /
    private void vuotoStateChanged(javax.swing.event.ChangeEvent evt) {// GEN-FIRST:event_vuotoStateChanged
        setCheckBoxState();
    }// GEN-LAST:event_vuotoStateChanged

    /**
     * Gestore del cambiamento di stato del radio button "Vaccino".
     * Attiva la modalità vaccino per immunizzare le persone.
        * /
    private void VaccinoStateChanged(javax.swing.event.ChangeEvent evt) {// GEN-FIRST:event_VaccinoStateChanged
        setCheckBoxState();
    }// GEN-LAST:event_VaccinoStateChanged

    /**
     * Gestore del cambiamento di stato del radio button "Quarantena".
     * Attiva la modalità quarantena per bloccare le persone.
        * /
    private void QuarantenaStateChanged(javax.swing.event.ChangeEvent evt) {// GEN-FIRST:event_QuarantenaStateChanged
        setCheckBoxState();
    }// GEN-LAST:event_QuarantenaStateChanged

    // ========================================
    // METODI DI AGGIORNAMENTO UI
    // ========================================
    
    /**
     * Aggiorna le statistiche visualizzate nell'interfaccia utente.
     * 
     * Chiamato durante la simulazione per mostrare:
     * - Popolazione corrente
     * - Numero di infetti
     * - Numero di immunizzati
     * - Media degli infetti
     * 
     * THREAD-SAFE: Metodo statico che può essere chiamato da qualsiasi thread.
     * 
     * @param popolazioneAggiornata Numero corrente di persone vive
     * @param infettiAggiornati Numero corrente di infetti
     * @param immuniAggiornati Numero corrente di immuni
        * /
    public static void setUI(int popolazioneAggiornata, int infettiAggiornati, double immuniAggiornati) {
        // Aggiorna le etichette con i nuovi valori
        jLabelPopolazione.setText("" + popolazioneAggiornata);
        jLabelInfetti.setText("" + infettiAggiornati);
        jLabelImmunizzati.setText("" + (int) immuniAggiornati);
        
        // Calcola la media degli infetti
        // Formula: (nuovi infetti - infetti iniziali) / nuovi infetti
        if (infettiAggiornati > 0) {
            MediaInfetti = (double) (infettiAggiornati - infetti) / (double) infettiAggiornati;
        } else {
            MediaInfetti = 0;
        }
        JlabelMediaInfetti.setText("" + fmt.format(MediaInfetti));
    }

    /**
     * Restituisce il tempo di quarantena configurato.
     * @return Tempo di quarantena in millisecondi
        * /
    public static int getTempoQuarantena() {
        return tempoQuarantena;
    }

    /**
     * Configura lo stato della checkbox e attiva/disattiva il listener del mouse.
     * 
     * Tre modalità:
     * - Vuoto (0): Nessuna azione, listener disattivato
     * - Vaccino (1): Selezione area per vaccinare, listener attivo
     * - Quarantena (-1): Selezione area per quarantena, listener attivo
        * /
    public void setCheckBoxState() {
        if (vuoto.isSelected()) {
            // Modalità vuota: disattiva tutto
            checkBox = 0;
            tempoQuarantena = 0;
            pandemia.RemoveListener();
            
        } else if (Vaccino.isSelected()) {
            // Modalità vaccino: attiva listener
            pandemia.setListener();
            tempoQuarantena = 0;
            checkBox = 1;
            
        } else if (Quarantena.isSelected()) {
            // Modalità quarantena: attiva listener e imposta durata
            pandemia.setListener();
            checkBox = -1;
            tempoQuarantena = (int) TempoQuarantena.getValue();
        }
    }

