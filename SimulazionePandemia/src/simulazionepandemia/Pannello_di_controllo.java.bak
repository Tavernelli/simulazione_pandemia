    /**
     * Gestore dell'evento click sul pulsante Start/Stop.
     * 
     * Al primo click:
     * - Inizializza la popolazione e i parametri
     * - Avvia la simulazione
     * 
     * Click successivi:
     * - Mette in pausa o riprende la simulazione
     * - Cambia il testo del pulsante (Start ↔ Stop)
     * 
     * @param evt Evento del pulsante
        * /
    private void StartActionPerformed(java.awt.event.ActionEvent evt) {// GEN-FIRST:event_StartActionPerformed
        if (!sceneBlocked) {
            // ========================================
            // AVVIO DELLA SIMULAZIONE
            // ========================================
            
            if (firstClick) {
                // Prima volta: inizializza tutti i parametri
                updatePopulationAndInfected();
                firstClick = false;
            }
            
            // Avvia la simulazione
            pandemia.setAppState(true);
            Start.setText("Stop");
            sceneBlocked = true;
            
        } else {
            // ========================================
            // PAUSA DELLA SIMULAZIONE
            // ========================================
            
            // Ferma la simulazione
            pandemia.setAppState(false);
            Start.setText("Start");
            sceneBlocked = false;
        }
    }// GEN-LAST:event_StartActionPerformed

    /**
     * Aggiorna i parametri della popolazione e delle infezioni.
     * 
     * Chiamato al primo avvio della simulazione per:
     * - Leggere tutti i valori dagli spinner
     * - Calcolare le percentuali se richiesto
     * - Inizializzare la popolazione nel pannello Pandemia
     * - Configurare i parametri epidemiologici
     * - Aggiornare le etichette dell'interfaccia
        * /
    private void updatePopulationAndInfected() {
        // ========================================
        // LETTURA PARAMETRI DALL'INTERFACCIA
        // ========================================
        
        popolazione = (int) PopolazioneIniziale.getValue();
        infetti = (int) InfettiIniziali.getValue();
        nuoviInfetti = (int) Infettivita.getValue();
        immuni = (int) Immuni.getValue();
        asintomatici = (int) Asintomatici.getValue();
        mortiInfetti = jCheckBoxMortiInfetti.isSelected() ? (int) Morti.getValue() : 0;

        // ========================================
        // CALCOLO PERCENTUALI (se richiesto)
        // ========================================
        
        if (PerncentualiInfetti.isSelected()) {
            // Converte il numero di infetti da percentuale a valore assoluto
            // Esempio: 10% di 100 persone = 10 persone
            infetti = Math.round(((float) popolazione) * (((float) infetti) / 100));
        }

        // ========================================
        // INIZIALIZZAZIONE SIMULAZIONE
        // ========================================
        
        // Inizializza la popolazione nel pannello di simulazione
        pandemia.SetPopolazioneIniziale(popolazione, infetti);

        // Configura i parametri epidemiologici
        pandemia.SetInfettività(nuoviInfetti, popolazione);
        pandemia.SetAsintomatici(asintomatici, nuoviInfetti);
        pandemia.SetmortiInfetti(mortiInfetti, nuoviInfetti);
        pandemia.SetGuaritiImmuni(immuni, nuoviInfetti);

        // ========================================
        // AGGIORNAMENTO INTERFACCIA
        // ========================================
        
        jLabelPopolazione.setText("" + popolazione);
        jLabelInfetti.setText(PerncentualiInfetti.isSelected() ? 
            "" + infetti : "" + InfettiIniziali.getValue());
        JlabelMediaInfetti.setText("" + fmt.format(0));
        
        // Cambia l'etichetta se si usano le percentuali
        jLabel6.setText(PerncentualiInfetti.isSelected() ? 
            jLabel6.getText() + " (%)" : "Infetti iniziali");
    }

