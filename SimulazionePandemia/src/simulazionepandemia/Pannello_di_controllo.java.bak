                public Pannello_di_controllo() {
                        initComponents();
                        frame = new JFrame("Pandemia");
                        frame.setSize(600, 600);
                        frame.setLocationRelativeTo(null);
                        frame.setResizable(false);
                        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
                        pandemia = new Pandemia();
                        frame.add(pandemia);
                        frame.pack();
                        frame.setVisible(true);

                        buttonGroup1.add(vuoto);
                        buttonGroup1.add(Vaccino);
                        buttonGroup1.add(Quarantena);

                        infetti = ((Integer) InfettiIniziali.getValue()).intValue();
                        popolazione = ((Integer) PopolazioneIniziale.getValue()).intValue();
                        asintomatici = ((Integer) Asintomatici.getValue()).intValue();
                        nuoviInfetti = ((Integer) Infettivita.getValue()).intValue();
                        immuni = ((Integer) Immuni.getValue()).intValue();
                        if (jCheckBoxMortiInfetti.isSelected()) {
                                mortiInfetti = ((Integer) Morti.getValue()).intValue();
                        }
                        jLabelPopolazione.setText(String.valueOf(popolazione));
                        jLabelInfetti.setText(String.valueOf(InfettiIniziali.getValue()));
                        JlabelMediaInfetti.setText("0");

                        Help.addActionListener(e -> showHelpDialog());

                        aggiungiDialogoVelocita();
                }

                private void aggiungiDialogoVelocita() {
                        JDialog speedDialog = new JDialog(this, "Velocità", false);
                        JPanel speedPanel = new JPanel(new BorderLayout(6,6));
                        JLabel lbl = new JLabel("Ritardo aggiornamento (ms)");
                        int currentDelay = 16;
                        try { currentDelay = pandemia.getUpdateDelayMillis(); } catch (Throwable ignore) {}
                        JSlider slider = new JSlider(5, 150, currentDelay);
                        slider.setMajorTickSpacing(25);
                        slider.setMinorTickSpacing(5);
                        slider.setPaintTicks(true);
                        JLabel val = new JLabel(String.valueOf(slider.getValue()));
                        slider.addChangeListener(new ChangeListener() {
                                public void stateChanged(ChangeEvent e) {
                                        int v = slider.getValue();
                                        val.setText(String.valueOf(v));
                                        pandemia.setUpdateDelayMillis(v);
                                }
                        });
                        speedPanel.add(lbl, BorderLayout.NORTH);
                        speedPanel.add(slider, BorderLayout.CENTER);
                        speedPanel.add(val, BorderLayout.EAST);
                        speedDialog.getContentPane().add(speedPanel);
                        speedDialog.pack();
                        speedDialog.setLocationRelativeTo(this);
                        speedDialog.setVisible(true);
                }

